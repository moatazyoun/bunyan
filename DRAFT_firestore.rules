rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny rule: block everything by default to ensure secure-by-default posture
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES AND HELPERS ---

    // Verifies whether the client initiating the query is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Validates a document identifier string to protect against ID Poisoning and path injection
    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Returns a map representing the incoming resource payload
    function incoming() {
      return request.resource.data;
    }

    // Returns a map representing the existing document resource currently persisted in Firestore
    function existing() {
      return resource.data;
    }

    // Looks up permissions securely on the database to verify if user has Admin privileges
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- SYSTEM TYPE SAFETY BLUEPRINTS ---

    // Validates correctness of user account state payloads
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'nameAr', 'role']) &&
             data.username is string && data.username.size() >= 1 && data.username.size() <= 128 &&
             data.nameAr is string && data.nameAr.size() >= 1 && data.nameAr.size() <= 256 &&
             data.role is string && (data.role == 'admin' || data.role == 'editor' || data.role == 'user');
    }

    // Validates correctness of construction site descriptions
    function isValidSite(data) {
      return data.keys().hasAll(['id', 'nameAr', 'location']) &&
             data.id is string && data.id.size() >= 1 && data.id.size() <= 128 &&
             data.nameAr is string && data.nameAr.size() >= 1 && data.nameAr.size() <= 256 &&
             data.location is string && data.location.size() >= 1 && data.location.size() <= 256;
    }

    // Ensures highly structured data ledgers are conformant list parameters
    function isValidSiteData(data) {
      return (data.transactions == null || data.transactions is list) &&
             (data.custodies == null || data.custodies is list) &&
             (data.contractors == null || data.contractors is list) &&
             (data.equipment == null || data.equipment is list) &&
             (data.workers == null || data.workers is list) &&
             (data.attendanceLogs == null || data.attendanceLogs is list);
    }

    // Ensures layout signing authorities contain expected list parameters
    function isValidExtractSettings(data) {
      return (data.signatories == null || data.signatories is list) &&
             (data.pageBookInfo == null || data.pageBookInfo is map) &&
             (data.headerTexts == null || data.headerTexts is map);
    }

    // --- COLLECTION ENDPOINTS MATCHERS ---

    // 1. Diagnostics Latency Path
    match /system/{docId} {
      allow read: if true; // Anyone can perform low-overhead diagnostics / ping checks
      allow write: if false; // Writing is restricted to prevent system spoofing
    }

    // 2. User Profiles
    match /users/{username} {
      // Signed-in construction team members can coordinate and find usernames
      allow read, list: if isSignedIn();
      
      // Creating a user profile is protected. If assigning 'admin', the author must already be admin.
      allow create: if isSignedIn() && isValidUser(incoming()) && 
                    (incoming().role != 'admin' || isAdmin());

      // Users can modify aspects of their own metadata, but cannot self-promote to admin roles
      allow update: if isSignedIn() && (request.auth.uid == username || isAdmin()) && 
                    isValidUser(incoming()) && 
                    (incoming().role == existing().role || isAdmin());

      allow delete: if isAdmin();
    }

    // 3. active Road Construction Sites
    match /sites/{siteId} {
      allow read, list: if isSignedIn();
      allow create, update: if isAdmin() && isValidId(siteId) && isValidSite(incoming());
      allow delete: if isAdmin();
    }

    // 4. Site transactional Ledger Data maps
    match /siteData/{siteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(siteId) && isValidSiteData(incoming());
      allow update: if isSignedIn() && isValidSiteData(incoming());
      allow delete: if isAdmin();
    }

    // 5. Extracts signatory templates
    match /extractSettings/{projectId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(projectId) && isValidExtractSettings(incoming());
      allow delete: if isAdmin();
    }

    // 6. Automated Daily Backups
    match /siteBackups/{backupId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(backupId);
      allow delete: if isAdmin();
    }
  }
}
