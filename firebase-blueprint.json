{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user account",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username" },
        "password": { "type": "string", "description": "Password or hash" },
        "nameAr": { "type": "string", "description": "Arabic full name and role description" },
        "role": { "type": "string", "description": "User privilege role (e.g., admin, editor)" }
      },
      "required": ["username", "password", "nameAr", "role"]
    },
    "Site": {
      "title": "Site",
      "description": "Active road construction work site",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique site matching URL slug" },
        "nameAr": { "type": "string", "description": "Site name in Arabic" },
        "location": { "type": "string", "description": "Geographic location outline" },
        "description": { "type": "string", "description": "Brief description of works" }
      },
      "required": ["id", "nameAr", "location"]
    },
    "SiteData": {
      "title": "SiteData",
      "description": "Deep data collection including financial ledger, supplies records, and daily logs for a given site",
      "type": "object",
      "properties": {
        "transactions": { "type": "array" },
        "custodies": { "type": "array" },
        "contractors": { "type": "array" },
        "equipment": { "type": "array" },
        "maintenanceOrders": { "type": "array" },
        "labTests": { "type": "array" },
        "hseIncidents": { "type": "array" },
        "wbsTasks": { "type": "array" },
        "warehouseItems": { "type": "array" },
        "auditLogs": { "type": "array" },
        "extracts": { "type": "array" },
        "supplyRecords": { "type": "array" },
        "supplyItems": { "type": "array" },
        "cubicCertificates": { "type": "array" },
        "contractorsReport": { "type": "array" },
        "fuelLogs": { "type": "array" },
        "custodyBudget": { "type": "number" },
        "equipmentSummary": { "type": "array" },
        "submissions": { "type": "array" }
      }
    },
    "ExtractSettings": {
      "title": "ExtractSettings",
      "description": "Financial reports signing authority lists and layout titles",
      "type": "object",
      "properties": {
        "signatories": { "type": "array", "description": "List of authorized engineers and signatories" },
        "pageBookInfo": { "type": "object", "description": "Accounting pages book data" },
        "headerTexts": { "type": "object", "description": "Header texts and project identification metadata" }
      }
    },
    "SystemPing": {
      "title": "SystemPing",
      "description": "System connectivity ping health tracking document",
      "type": "object",
      "properties": {
        "ping": { "type": "string" }
      }
    },
    "SiteBackup": {
      "title": "SiteBackup",
      "description": "Structured daily backup archives of a given site's data ledger",
      "type": "object",
      "properties": {
        "siteId": { "type": "string" },
        "siteName": { "type": "string" },
        "backupDate": { "type": "string" },
        "createdAt": { "type": "string" },
        "payload": { "type": "object" }
      },
      "required": ["siteId", "backupDate", "createdAt", "payload"]
    },
    "HSEIncident": {
      "title": "HSEIncident",
      "description": "Health, Safety, and Environment Incident",
      "type": "object",
      "properties": {
        "refNumber": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "type": { "type": "string", "enum": ["injury", "near_miss", "property_damage", "environmental"] },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "reportedBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["refNumber", "projectId", "description", "status"]
    },
    "HSEAudit": {
      "title": "HSEAudit",
      "description": "Health, Safety, and Environment Audit",
      "type": "object",
      "properties": {
        "refNumber": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["ppe", "equipment", "fire_extinguisher"] },
        "score": { "type": "number" },
        "status": { "type": "string", "enum": ["passed", "failed", "needs_action"] },
        "inspector": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["refNumber", "projectId", "score", "status"]
    },
    "HSEActivityLog": {
      "title": "HSEActivityLog",
      "description": "Audit log for HSE actions",
      "type": "object",
      "properties": {
        "refNumber": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "performedBy": { "type": "string" },
        "timestamp": { "type": "string" },
        "severity": { "type": "string" }
      },
      "required": ["refNumber", "action", "module"]
    }
  },
  "firestore": {
    "/hse_incidents/{incidentId}": {
      "schema": "HSEIncident",
      "description": "Collection of HSE incidents"
    },
    "/hse_audits/{auditId}": {
      "schema": "HSEAudit",
      "description": "Collection of HSE audits"
    },
    "/hse_activity_logs/{logId}": {
      "schema": "HSEActivityLog",
      "description": "Audit logs for HSE actions"
    },
    "/users/{username}": {
      "schema": "User",
      "description": "Collection of system management users"
    },
    "/sites/{siteId}": {
      "schema": "Site",
      "description": "Collection of road works sites"
    },
    "/siteData/{siteId}": {
      "schema": "SiteData",
      "description": "Highly structured records for each site containing transactions, logs, and sub-databases"
    },
    "/extractSettings/{projectId}": {
      "schema": "ExtractSettings",
      "description": "Customizable signatures and header text templates for engineering reports"
    },
    "/system/{docId}": {
      "schema": "SystemPing",
      "description": "Network latency status check database references"
    },
    "/siteBackups/{backupId}": {
      "schema": "SiteBackup",
      "description": "Backups of active sites structured data"
    }
  }
}
