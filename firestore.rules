rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global fallback for all authenticated users to prevent permission blocks
    // during multi-tenant isolation testing.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit collection matches (redundant but helps with clarity)
    match /users/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /sites/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /siteData/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /activityLogs/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /siteBackups/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
